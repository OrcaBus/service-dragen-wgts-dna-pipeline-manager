{
  "Comment": "Convert a READY event to an ICAv2 WES request event, with initial comment for traceability",
  "StartAt": "Save inputs",
  "States": {
    "Save inputs": {
      "Type": "Pass",
      "Next": "Add Ready Comment",
      "Assign": {
        "dragenWgtsDnaReadyEventDetail": "{% $states.input %}"
      }
    },
    "Add Ready Comment": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Arguments": {
        "FunctionName": "${__add_ready_comment_lambda_function_arn__}",
        "Payload": {
          "workflowRunId": "{% $dragenWgtsDnaReadyEventDetail.orcabusId %}",
          "executionArn": "{% $states.context.Execution.Id %}"
        }
      },
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.SdkClientException",
            "Lambda.TooManyRequestsException"
          ],
          "IntervalSeconds": 1,
          "MaxAttempts": 3,
          "BackoffRate": 2,
          "JitterStrategy": "FULL"
        }
      ],
      "Next": "Convert Dragen WGTS DNA Ready Event to ICAv2 WES Event",
      "Output": "{% $states.input %}"
    },
    "Convert Dragen WGTS DNA Ready Event to ICAv2 WES Event": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Arguments": {
        "FunctionName": "${__dragen_wgts_dna_ready_to_icav2_wes_request_lambda_function_arn__}",
        "Payload": {
          "dragenWgtsDnaReadyEventDetail": "{% $dragenWgtsDnaReadyEventDetail %}"
        }
      },
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.SdkClientException",
            "Lambda.TooManyRequestsException"
          ],
          "IntervalSeconds": 1,
          "MaxAttempts": 3,
          "BackoffRate": 2,
          "JitterStrategy": "FULL"
        }
      ],
      "Next": "Push WES Event",
      "Output": {
        "icav2WesRequestEventDetail": "{% $states.result.Payload.icav2WesRequestEventDetail %}"
      }
    },
    "Push WES Event": {
      "Type": "Task",
      "Resource": "arn:aws:states:::events:putEvents",
      "Arguments": {
        "Entries": [
          {
            "Detail": "{% $states.input.icav2WesRequestEventDetail %}",
            "DetailType": "${__icav2_wes_request_detail_type__}",
            "EventBusName": "${__event_bus_name__}",
            "Source": "${__stack_source__}"
          }
        ]
      },
      "End": true
    }
  },
  "QueryLanguage": "JSONata"
}
